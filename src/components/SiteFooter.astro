---
import Icon from "./Icon.astro";
import { site } from "../config/site";
---

<footer class="site-footer">
  <div class="bg-[var(--secondary)] text-[var(--footer-text)] [&_a]:text-[var(--footer-text)] [&_a:focus]:text-[var(--footer-text)] [&_a:hover]:text-[var(--footer-text)]">
    <div class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-8 px-2 py-6 md:grid-cols-3">
      <section>
        <h4 class="text-[var(--white)]">{ site.title }</h4>
        {
          site.footer.text.map((paragraph) => (
            <p>{paragraph}</p>
          ))
        }
      </section>
      <section>
        <h4 class="text-[var(--white)]">{ site.footer.contact }</h4>
        <p class="flex items-center gap-4"><Icon name="fa-mobile" class="h-7 w-7 text-[var(--footer-bg-dark)]" /><a href={`tel:${site.phone_short}`}>{ site.phone }</a></p>
        <p class="flex items-center gap-4"><Icon name="fa-envelope-open-text" class="h-7 w-7 text-[var(--footer-bg-dark)]" /><a href={`mailto:${site.email}`}>{ site.email }</a></p>
      </section>
      <section>
        <h4 class="text-[var(--white)]">{ site.footer.instagram.title }</h4>
        <p>
          Placeholder paragraph content for the third footer column with a
          <a href="#">placeholder link</a>.
        </p>
      </section>
    </div>
  </div>
  <div class="bg-[var(--footer-bg-dark)] text-[var(--footer-text-dark)] [&_a]:text-[var(--footer-text-dark)] [&_a:focus]:text-[var(--footer-text-dark)] [&_a:hover]:text-[var(--footer-text-dark)]">
    <div class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-4 px-2 py-4 md:grid-cols-2">
      <div>{ site.title } &copy; Copyright { new Date().getFullYear() }</div>
      <div class="md:justify-self-end md:text-right">
        <ul class="flex flex-wrap gap-x-4 gap-y-1 md:justify-end">
          {
            site.nav.map((item) => (
              <li>
                <a href={item.url}>{item.title}</a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</footer>
