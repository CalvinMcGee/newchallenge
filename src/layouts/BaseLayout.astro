---
import ContactSection from "../components/ContactSection.astro";
import { site } from "../config/site";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteNav from "../components/SiteNav.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  frontmatter?: {
    title?: string;
  };
}

const { title, frontmatter } = Astro.props;
const pageTitle = title ?? frontmatter?.title;
const isHomePage = Astro.url.pathname === "/";
const documentTitle = isHomePage || !pageTitle ? site.title : `${pageTitle} - ${site.title}`;
const visiblePageTitle = pageTitle ?? site.title;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{documentTitle}</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Open+Sans:400,600i,700" />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
  </head>
  <body>
    <div class="site-shell">
      <SiteHeader />
      <SiteNav />
      <main class="flex-1 py-8">
        <div class="mx-auto w-full max-w-6xl px-2">
          <article>
            <h1 class="mb-6 text-center text-2xl font-semibold italic">{visiblePageTitle}</h1>
            <slot />
          </article>
        </div>
      </main>
      <ContactSection />
      <SiteFooter />
    </div>

    <!-- SCRIPTS -->
    <script src="https://www.google.com/recaptcha/api.js?hl=sv" async defer></script>
  </body>
</html>
