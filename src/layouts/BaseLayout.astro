---
import ContactSection from "../components/ContactSection.astro";
import FeatureSection from "../components/FeatureSection.astro";
import { site } from "../config/site";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteNav from "../components/SiteNav.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  frontmatter?: {
    title?: string;
    feature?: {
      title: string;
      sections: Array<{
        icon: "fa-mobile" | "fa-envelope-open-text" | "fa-user" | "fa-chalkboard-teacher";
        title: string;
        body: string;
        url: string;
      }>;
    };
  };
}

const { title, frontmatter } = Astro.props;
const pageTitle = title ?? frontmatter?.title;
const isHomePage = Astro.url.pathname === "/";
const documentTitle = isHomePage || !pageTitle ? site.title : `${pageTitle} - ${site.title}`;
const visiblePageTitle = pageTitle ?? site.title;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{documentTitle}</title>
    <link rel="preload" as="image" href="/img/header.webp" type="image/webp" fetchpriority="high" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Open+Sans:400,600i,700&display=swap" />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
  </head>
  <body>
    <div class="site-shell">
      <div class="relative">
        <div class="absolute inset-x-0 top-0 z-30">
          <SiteNav />
        </div>
        <SiteHeader />
      </div>
      <main class="flex-1 py-12 md:py-24">
        <div class="mx-auto w-full max-w-6xl px-2">
          <article>
            <h1 class="mb-8 md:mb-18 text-center text-2xl font-semibold italic whitespace-pre-line">{visiblePageTitle}</h1>
            <slot />
            {frontmatter?.feature && <FeatureSection feature={frontmatter.feature} />}
          </article>
        </div>
      </main>
      <ContactSection />
      <SiteFooter />
    </div>

  </body>
</html>
