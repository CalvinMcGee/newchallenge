---
import ContactSection from "../components/ContactSection.astro";
import FeatureSection from "../components/FeatureSection.astro";
import { site } from "../config/site";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteNav from "../components/SiteNav.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  frontmatter?: {
    title?: string;
    feature?: {
      title: string;
      sections: Array<{
        icon: "fa-mobile" | "fa-envelope-open-text" | "fa-user" | "fa-chalkboard-teacher";
        title: string;
        body: string;
        url: string;
      }>;
    };
  };
}

const { title, frontmatter } = Astro.props;
const pageTitle = title ?? frontmatter?.title;
const isHomePage = Astro.url.pathname === "/";
const documentTitle = isHomePage || !pageTitle ? site.title : `${pageTitle} - ${site.title}`;
const visiblePageTitle = pageTitle ?? site.title;
const criticalCss = `
  :root {
    --white: #fefefe;
    --bg: #f5f7f8;
    --text: #1b2a31;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
  }

  body {
    margin: 0;
    color: var(--text);
    background: linear-gradient(180deg, #edf3f5 0%, #f5f7f8 30%, #f5f7f8 100%);
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  h1,
  h2 {
    margin: 0;
    line-height: 1.2;
  }

  .site-shell {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .site-nav-shell {
    background: linear-gradient(180deg, rgba(17, 29, 35, 0.78) 0%, rgba(17, 29, 35, 0.58) 68%, rgba(17, 29, 35, 0) 100%);
    color: var(--white);
  }

  .site-header-shell {
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .site-header-image,
  .site-header-overlay {
    position: absolute;
    inset: 0;
  }

  .site-header-image {
    z-index: -2;
    height: 100%;
    width: 100%;
    object-fit: cover;
  }

  .site-header-overlay {
    z-index: -1;
    background: rgb(0 0 0 / 0.1);
  }

  .site-header-content {
    margin-inline: auto;
    position: relative;
    z-index: 1;
    display: flex;
    min-height: 50vh;
    width: 100%;
    max-width: 72rem;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 7rem 0.5rem 2.5rem;
  }

  .site-header-logo-link {
    display: block;
    width: 58.333333%;
  }

  .site-header-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    color: var(--white);
  }

  .site-header-copy h2 {
    font-size: 1.875rem;
    font-weight: 600;
    font-style: italic;
    text-wrap: balance;
  }

  @media (min-width: 48rem) {
    .site-header-content {
      gap: 2rem;
      padding-top: 9rem;
      padding-bottom: 3.5rem;
    }

    .site-header-logo-link {
      width: 41.666667%;
    }
  }

  @media (min-width: 64rem) {
    .site-header-logo-link {
      width: 33.333333%;
    }
  }
`;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{documentTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Open+Sans:400,600i,700&display=swap" />
    <style is:inline set:html={criticalCss}></style>
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
  </head>
  <body>
    <div class="site-shell">
      <div class="relative">
        <div class="absolute inset-x-0 top-0 z-30">
          <SiteNav />
        </div>
        <SiteHeader />
      </div>
      <main class="flex-1 py-12 md:py-24">
        <div class="mx-auto w-full max-w-6xl px-2">
          <article>
            <h1 class="mb-8 md:mb-18 text-center text-2xl font-semibold italic whitespace-pre-line">{visiblePageTitle}</h1>
            <slot />
            {frontmatter?.feature && <FeatureSection feature={frontmatter.feature} />}
          </article>
        </div>
      </main>
      <ContactSection />
      <SiteFooter />
    </div>

  </body>
</html>
